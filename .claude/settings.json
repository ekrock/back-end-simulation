      "Bash(git add *)",
      "Bash(git add --all)",
      "Bash(git commit -m *)",
      "Bash(git commit -F /tmp/*)",
      "Bash(git push)",
      "Bash(git push origin main)",
      "Bash(git push origin main *)",
      "Bash(git restore --staged *)",
      "Bash(ssh back-end-sim-ec2 'cd ~/back-end-simulation && git pull')",
      "Bash(ssh back-end-sim-ec2 'cd ~/back-end-simulation && git pull origin main')",
      "Bash(ssh back-end-sim-ec2 'cd ~/back-end-simulation && source venv/bin/activate && pip install -r requirements.txt')",
