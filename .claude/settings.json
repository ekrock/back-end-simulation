{
  "permissions": {
    "allow": [
      "Bash(git -C /Users/eric/back-end-simulation *)",
      "Bash(git add *)",
      "Bash(git commit -m *)",
      "Bash(git commit -F /tmp/*)",
      "Bash(git push)",
      "Bash(git restore --staged *)",
      "Bash(ssh back-end-sim-ec2 'cd ~/back-end-simulation/deploy && git pull')",
      "Bash(ssh back-end-sim-ec2 'cd ~/back-end-simulation && source venv/bin/activate && pip install -r deploy/requirements.txt')",
      "Bash(ssh back-end-sim-ec2 'sudo systemctl restart back-end-simulation.service')",
      "Bash(ssh back-end-sim-ec2 'sudo systemctl status back-end-simulation.service')",
      "Bash(ssh back-end-sim-ec2 'sudo journalctl -u back-end-simulation*')",
      "Bash(ssh back-end-sim-ec2 'cat ~/back-end-simulation/*')",
      "Bash(ssh back-end-sim-ec2 'ls ~/back-end-simulation/*')",
      "Edit(/Users/eric/back-end-simulation/**)",
      "Write(/Users/eric/back-end-simulation/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -n --arg brief \"$(cat /Users/eric/back-end-simulation/BRIEF.md)\" --arg decisions \"$(cat /Users/eric/back-end-simulation/DECISIONS.md)\" '{\"hookSpecificOutput\": {\"hookEventName\": \"SessionStart\", \"additionalContext\": (\"BRIEF.md:\\n\" + $brief + \"\\n\\nDECISIONS.md:\\n\" + $decisions)}}'",
            "statusMessage": "Restoring project context..."
          }
        ]
      }
    ]
  }
}
