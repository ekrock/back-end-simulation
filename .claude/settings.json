      "Bash(ssh back-end-sim-ec2 'cd ~/back-end-simulation && bash scripts/maintenance/*')",
      "Bash(ssh back-end-sim-ec2 'bash ~/back-end-simulation/scripts/maintenance/*')",
      "Bash(ssh back-end-sim-ec2 'sudo systemctl restart back-end-simulation*')",
      "Bash(ssh back-end-sim-ec2 'sudo systemctl reload back-end-simulation*')",
      "Bash(ssh back-end-sim-ec2 'sudo systemctl status back-end-simulation*')",
      "Bash(ssh back-end-sim-ec2 'sudo systemctl daemon-reload')",
      "Bash(ssh back-end-sim-ec2 'sudo journalctl -u back-end-simulation*')",
      "Bash(ssh back-end-sim-ec2 'ls ~/back-end-simulation/*')",
      "Bash(ssh back-end-sim-ec2 'cat ~/back-end-simulation/*')",
      "Bash(ssh back-end-sim-ec2 'grep *')",
      "Bash(ssh back-end-sim-ec2 'python3 *')",
      "Bash(ssh back-end-sim-ec2 \"python3 *\")",
      "Bash(scp back-end-sim-ec2:~/back-end-simulation/*)",
      "Bash(scp /tmp/*.py back-end-sim-ec2:/tmp/*)",
      "Bash(scp back-end-sim-ec2:/tmp/*)",
      "Bash(scp *)",
      "Bash(sed *)",
      "Bash(sips -g*)",
      "Bash(aws secretsmanager get-secret-value*)",
      "Bash(log show *)",
      "Bash(/usr/bin/python3 -c *)",
      "Bash(/usr/bin/python3 *)",
      "Bash(/opt/homebrew/bin/python3.12 *)",
      "Bash(/opt/homebrew/bin/python3 *)",
      "Bash(brew install *)",
      "Bash(brew list *)",
      "Bash(brew info *)",
      "Bash(brew --version)",
      "Bash(brew update)",
      "Bash(brew upgrade *)",
      "Bash(which *)",
      "Bash(xattr *)",
      "Bash(curl -s *)",
      "Bash(curl -sk *)",
      "Bash(curl -sI *)",
      "Edit(/Users/eric/back-end-simulation/**)",
      "Write(/Users/eric/back-end-simulation/**)",
      "Write(/tmp/*)",
      "Edit(/tmp/*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -n --rawfile brief /Users/eric/back-end-simulation/BRIEF.md --rawfile decisions /Users/eric/back-end-simulation/DECISIONS.md '{hookSpecificOutput: {hookEventName: \"SessionStart\", additionalContext: (\"Back-end-simulation project context (auto-loaded on session start):\\n\\n=== BRIEF.md ===\\n\" + $brief + \"\\n=== DECISIONS.md ===\\n\" + $decisions)}}'",
            "statusMessage": "Restoring project context..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "printf '%s' '{\"systemMessage\":\"PreCompact reminder: before /compact, audit substantive non-code topics from this session and save each to docs/*.md (indexed in README) so they survive the summary. Skip if no such topics exist.\"}'"
          }
        ]
      }
    ]
  }
}
